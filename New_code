  <div class="menu-panel">
    <nav class="menu-nav">
      <a href="https://www.mycaptain.com/booking/endgamefishing" target="_blank" rel="noopener">Book Now</a>
      <a href="#" id="manifestoLink">Manifesto</a>
    </nav>
    <div class="menu-divider"></div>
    <div class="menu-tag">Naples, Florida &mdash; Endgame Fishing</div>
  </div>
</div>

<div class="manifesto-page" id="manifestoPage">
  <button class="m-close" id="mClose">Back</button>
  <div class="manifesto-inner">
    <div class="m-head">Our Water. Our Code.</div>
    <div class="m-body">
      <p class="em">We are not tourists.<br>We are not weekend warriors.<br>We are not here to drift.</p>
      <p>We are captains.<br>A small circle. Handpicked. Earned &mdash; not claimed.</p>
      <p>We read tides like scripture.<br>We track wind like blood pressure.<br>We move with precision.</p>
      <p>We do not guess. We know.</p>
      <p>Out here, excuses sink.<br>The ocean does not care about ego.<br>Mother Nature does not negotiate.</p>
      <p>She rewards discipline.<br>She punishes arrogance.<br>And we respect her.</p>
      <p>We do not overharvest.<br>We do not waste.<br>We do not leave scars on the water.</p>
      <p>If we take, we give back.<br>If we fish, we steward.<br>If we lead, we protect.</p>
      <p>Conservation is not a marketing word to us.<br>It is law.<br>It is lineage.<br>It is legacy.</p>
      <p>We release with intention.<br>We handle with care.<br>We fight hard &mdash; and we respect harder.</p>
      <p>We don&rsquo;t play around on the water.<br>Not with safety.<br>Not with the fish.<br>Not with each other.</p>
      <p>Gear is dialed.<br>Knots are clean.<br>Engines are ready.<br>Minds are sharp.</p>
      <p>Every cast has purpose.<br>Every decision has weight.<br>Every trip leaves the water better than we found it.</p>
      <p>This is not a hobby.<br>This is not a vibe.<br>This is a code.</p>
      <p>Elite doesn&rsquo;t mean loud.<br>It means disciplined.<br>It means prepared.<br>It means accountable when no one is watching.</p>
      <p>We are here for the long game.<br>For the next generation.<br>For the waters that raised us.<br>For the fish that feed us.</p>
      <p class="em">We answer to tide and time.<br>And we leave nothing behind but wake.</p>
      <p class="manifesto-closing">What's your endgame?</p>
    </div>
  </div>
</div>

<script>
  function tick() {
    const t = new Date().toLocaleTimeString('en-US', {
      timeZone: 'America/New_York',
      hour: 'numeric', minute: '2-digit', hour12: true
    });
    document.getElementById('naplesClock').textContent = t;
  }
  tick(); setInterval(tick, 1000);

  const slides = document.querySelectorAll('.slide');
  const dotsEl = document.getElementById('dots');
  let cur = 0, timer;

  slides.forEach((_,i) => {
    const d = document.createElement('div');
    d.className = 'dot' + (i===0?' active':'');
    dotsEl.appendChild(d);
  });

  function goTo(n) {
    slides[cur].classList.remove('active');
    dotsEl.children[cur].classList.remove('active');
    cur = n;
    const s = slides[cur];
    if (s.dataset.bg) { s.style.backgroundImage = "url('" + s.dataset.bg + "')"; delete s.dataset.bg; }
    s.classList.add('active');
    dotsEl.children[cur].classList.add('active');
  }

  timer = setInterval(() => goTo((cur+1) % slides.length), 5500);

  const hbg = document.getElementById('hbg');
  const menuOverlay = document.getElementById('menuOverlay');
  hbg.addEventListener('click', () => {
    hbg.classList.toggle('open');
    menuOverlay.classList.toggle('open');
  });
  menuOverlay.addEventListener('click', e => {
    if (e.target === menuOverlay) {
      hbg.classList.remove('open');
      menuOverlay.classList.remove('open');
    }
  });

  const manifestoPage = document.getElementById('manifestoPage');
  document.getElementById('manifestoLink').addEventListener('click', e => {
    e.preventDefault();
    hbg.classList.remove('open');
    menuOverlay.classList.remove('open');
    manifestoPage.classList.add('visible');
    clearInterval(timer);
  });
  document.getElementById('mClose').addEventListener('click', () => {
    manifestoPage.classList.remove('visible');
    manifestoPage.scrollTop = 0;
    timer = setInterval(() => goTo((cur+1) % slides.length), 5500);
  });
</script>
</body>
